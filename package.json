{
  "name": "@harborclient/plugin-interval",
  "version": "1.0.4",
  "type": "module",
  "scripts": {
    "build": "esbuild src/renderer.tsx --bundle --outfile=dist/renderer.js --format=esm --jsx=automatic --jsx-import-source=@harborclient/sdk --external:react --external:react-dom --alias:react/jsx-runtime=@harborclient/sdk/jsx-runtime --alias:react/jsx-dev-runtime=@harborclient/sdk/jsx-dev-runtime && pnpm verify:renderer",
    "dev": "esbuild src/renderer.tsx --bundle --outfile=dist/renderer.js --format=esm --jsx=automatic --jsx-import-source=@harborclient/sdk --external:react --external:react-dom --alias:react/jsx-runtime=@harborclient/sdk/jsx-runtime --alias:react/jsx-dev-runtime=@harborclient/sdk/jsx-dev-runtime --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:renderer": "node --experimental-strip-types scripts/verify-renderer.ts",
    "test": "vitest run",
    "pack": "pnpm build && zip -r ../harborclient-plugin-interval.hcp manifest.json README.md dist",
    "plugin:sign": "node --experimental-strip-types scripts/plugin-sign.ts",
    "plugin:verify": "node --experimental-strip-types scripts/plugin-verify.ts"
  },
  "dependencies": {
    "@harborclient/sdk": "^0.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.2",
    "esbuild": "^0.25.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.4"
  }
}
