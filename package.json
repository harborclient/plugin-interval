{
  "name": "@harborclient/plugin-interval",
  "type": "module",
  "scripts": {
    "release": "bash scripts/publish.sh",
    "build": "node scripts/build.mjs && pnpm verify:renderer",
    "dev": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:renderer": "node --experimental-strip-types scripts/verify-renderer.ts",
    "test": "vitest run",
    "pack": "pnpm build && zip -r ../harborclient-plugin-interval.hcp manifest.json README.md dist",
    "sign": "node --experimental-strip-types scripts/plugin-sign.ts",
    "verify": "node --experimental-strip-types scripts/plugin-verify.ts"
  },
  "dependencies": {
    "@harborclient/sdk": "^1.0.67"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.2",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
